# Copy to .env and adjust. Used by app and Alembic (DATABASE_URL overrides).

# Database (default: SQLite for local dev)
# DATABASE_URL=sqlite:///./orchestrator.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/orchestrator

# Optional
# DEBUG=false
# APP_NAME=Data Pipeline Orchestrator
# RETENTION_DAYS_DEFAULT=90
